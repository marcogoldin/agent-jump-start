{
  "name": "@marcogoldin/agent-jump-start",
  "version": "1.17.0",
  "description": "Portable starter kit for keeping AI coding assistant instructions synchronized across 12 agent ecosystems from one canonical specification.",
  "type": "module",
  "main": "scripts/agent-jump-start.mjs",
  "bin": {
    "agent-jump-start": "scripts/agent-jump-start.mjs"
  },
  "scripts": {
    "init": "node scripts/agent-jump-start.mjs init",
    "bootstrap": "node scripts/agent-jump-start.mjs bootstrap --base specs/base-spec.yaml",
    "render": "node scripts/agent-jump-start.mjs render --spec canonical-spec.yaml --target .",
    "render:clean": "node scripts/agent-jump-start.mjs render --spec canonical-spec.yaml --target . --clean",
    "check": "node scripts/agent-jump-start.mjs check --spec canonical-spec.yaml --target .",
    "validate": "node scripts/agent-jump-start.mjs validate --spec canonical-spec.yaml",
    "test": "node --test",
    "smoke:p0": "node scripts/ci/smoke-single-command-trust.mjs",
    "smoke:preserve": "node scripts/ci/smoke-preserve-unmanaged-files.mjs",
    "smoke:absorb": "node scripts/ci/smoke-absorb.mjs",
    "export-schema": "node scripts/agent-jump-start.mjs export-schema",
    "list-agents": "node scripts/agent-jump-start.mjs list-agents",
    "list-profiles": "node scripts/agent-jump-start.mjs list-profiles"
  },
  "keywords": [
    "ai",
    "coding-assistant",
    "claude",
    "copilot",
    "gemini",
    "amazon-q",
    "cursor",
    "windsurf",
    "cline",
    "aider",
    "agent",
    "instructions",
    "memory-injection",
    "developer-tools",
    "vscode",
    "ide"
  ],
  "author": "Marco Goldin",
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcogoldin/agent-jump-start.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "scripts/",
    "lib/",
    "specs/",
    "docs/layered-specs.md",
    "prompts/",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
